# Copy this file to ".env" and fill in your key.
#
# Google Gemini API key (Google AI Studio / Generative Language API).
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gcp-gemini-api-key-here

# Model used for planning + reasoning. See app/config.py for the pricing table.
# Good options: gemini-2.0-flash (default), gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# Local embedding + reranker models (downloaded once on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
